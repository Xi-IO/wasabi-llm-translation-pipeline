# Primary provider/model (recommended)
PRIMARY_PROVIDER=qwen
PRIMARY_MODEL=qwen-plus

# Backward-compatible aliases (optional; PRIMARY_* has higher priority)
PROVIDER=qwen
MODEL=qwen-plus

# Optional content-filter fallback provider
FALLBACK_ON_CONTENT_FILTER=false
FALLBACK_PROVIDER=grok
FALLBACK_MODEL=grok-4.1-fast

# Provider API keys
QWEN_API_KEY=YOUR_QWEN_API_KEY
MIMO_API_KEY=YOUR_MIMO_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GROK_API_KEY=YOUR_GROK_API_KEY

# Optional provider-specific base URL override
# GROK_BASE_URL=https://api.x.ai/v1
